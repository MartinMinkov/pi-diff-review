{
  "name": "pi-diff-review",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "check:web": "tsc -p tsconfig.web.json",
    "build:web": "node scripts/build-web.mjs",
    "postinstall": "node scripts/ensure-glimpse-host.mjs",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "patchedDependencies": {
      "glimpseui@0.6.0": "patches/glimpseui@0.6.0.patch"
    }
  },
  "pi": {
    "extensions": [
      "./src/host/command/register-diff-review.ts"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.69.0",
    "glimpseui": "^0.6.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260313.1",
    "husky": "^9.1.7",
    "typescript": "^5.9.2"
  }
}
